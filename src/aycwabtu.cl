/* AYCWABTU OpenCL kernel - CSA brute-force on GPU.
   Phase 1: Exact port of libdvbcsa stream and block ciphers.
   Each work-item processes one outer key and loops over the
   16-bit inner key space (bytes 5,6).                           */

/* ---- type aliases ---- */
typedef unsigned char  u8;
typedef unsigned int   u32;
typedef unsigned long  u64;
typedef unsigned short u16;

