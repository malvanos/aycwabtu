/* Stream output byte generation table */
__constant u8 stream_out[16] = {
    0x00, 0x55, 0x55, 0x00, 0xaa, 0xff, 0xff, 0xaa,
    0xaa, 0xff, 0xff, 0xaa, 0x00, 0x55, 0x55, 0x00,
};

/* ================================================================
   Stream cipher - exact port from libdvbcsa/dvbcsa_stream.c
   ================================================================ */

/* Get nibble from 64-bit register. n is nibble index (0..15) */
#define NBGET(r, n) ((u8)(((r) >> ((n) * 4)) & 0xf))

/* Register access helpers */
#define GETX(x)  ((x) & 0xf)
#define GETY(x)  (((x) >> 4) & 0xf)
#define GETD(x)  ((x) & 0xf)
#define TSTP(x)  ((x) & 0x1000)

/* Nibble swap in byte */
static inline u8 swap_nbl(u8 byte) {
    return (u8)((byte >> 4) | (byte << 4));
}

/* Conditional rotation used in stream round */
static inline u32 stream_rotate(u32 pqzyx, u32 x) {
    return TSTP(pqzyx) ? (((x << 1) | ((x >> 3) & 1)) & 0xf) : x;
}

/* 7 sbox computation - exact from libdvbcsa */
static u32 stream_sboxes(u64 A) {
    u32 res;
    u64 t;

    t = A & 0x2018004200UL;
    res  = stream_sbox[1][(u32)(((t >> 37) ^ (t >> 27) ^ (t >> 25) ^ (t >> 11) ^ (t >>  5)) & 0x1f)];

    t = A & 0x4201480000UL;
    res |= stream_sbox[4][(u32)(((t >> 38) ^ (t >> 32) ^ (t >> 22) ^ (t >> 16) ^ (t >> 18)) & 0x1f)];

    t = A & 0x8040122000UL;
    res |= stream_sbox[5][(u32)(((t >> 39) ^ (t >> 29) ^ (t >> 18) ^ (t >> 14) ^ (t >>  9)) & 0x1f)];

    t = A & 0x1082010040UL;
    res |= stream_sbox[0][(u32)(((t >> 36) ^ (t >> 30) ^ (t >> 23) ^ (t >>  3) ^ (t >> 12)) & 0x1f)];

    t = A & 0x0004a00180UL;
    res |= stream_sbox[2][(u32)(((t >> 26) ^ (t >> 22) ^ (t >> 19) ^ (t >>  5) ^ (t >>  3)) & 0x1f)];

    t = A & 0x0100048820UL;
    res |= stream_sbox[3][(u32)(((t >> 32) ^ (t >> 17) ^ (t >>  9) ^ (t >>  2) ^ (t >> 11)) & 0x1f)];

    t = A & 0x0c20001400UL;
    res |= stream_sbox[6][(u32)(((t >> 35) ^ (t >> 33) ^ (t >> 27) ^ (t >>  9) ^ (t >>  6)) & 0x1f)];

    return res;
}

/* Bit selection and XOR from B register - exact from libdvbcsa */
static u32 stream_B_sel(u64 B) {
    u32 t = (u32)(B >> 9);
    u32 r = 0;
    r ^= (((t      )                         ^ (t >> 27)) & 0x8);
    r ^= (((t >> 18)                                    ) & 0x9);
    r ^= ((            (t >> 22)             ^ (t >>  7)) & 0x4);
    r ^= (((t >> 4 )                                    ) & 0x5);
    r ^= ((            (t >> 24) ^ (t >>  6) ^ (t >> 11)) & 0x2);
    r ^= (((t >> 29) ^                         (t >> 23)) & 0x1);
    r ^= (((t >> 13)                                    ) & 0xe);
    return r;
}

/* CFED precomputed operations - exact from libdvbcsa */
static u32 stream_cfed(u32 pqzyx, u32 cfed) {
    return ((cfed & 0x0f00) >> 4) |
           stream_cdef[((cfed & 0x10ff) | (pqzyx & 0x2f00)) >> 4];
}

/* Stream cipher init round - exact from libdvbcsa */
static void stream_init_round(u8 iv_byte, u64 *A, u64 *B, u32 *pqzyx, u32 *cfed) {
    u32 tmp;

    *A <<= 4;
    *A |= (NBGET(*A, 10) ^ GETX(*pqzyx) ^ GETD(*cfed) ^ (iv_byte >> 4)) & 0x0f;

    tmp = (NBGET(*B, 6) ^ NBGET(*B, 9) ^ GETY(*pqzyx) ^ iv_byte) & 0x0f;
    tmp = stream_rotate(*pqzyx, tmp);

    *B <<= 4;
    *B |= tmp;

    *cfed = stream_cfed(*pqzyx, *cfed) ^ stream_B_sel(*B);

    *pqzyx = stream_sboxes(*A);
}

/* Stream cipher generation round - exact from libdvbcsa */
static void stream_round(u64 *A, u64 *B, u32 *pqzyx, u32 *cfed) {
    u32 tmp;

    *A <<= 4;
    *A |= (NBGET(*A, 10) ^ GETX(*pqzyx)) & 0xf;

    tmp = (NBGET(*B, 6) ^ NBGET(*B, 9) ^ GETY(*pqzyx)) & 0xf;

    *B <<= 4;
    *B |= stream_rotate(*pqzyx, tmp);

    *cfed = stream_cfed(*pqzyx, *cfed) ^ stream_B_sel(*B);

    *pqzyx = stream_sboxes(*A);
}

/* Stream cipher XOR - decrypts residual data (bytes 8+ of TS packet).
   cw: 8-byte nibble-swapped control word (cws)
   iv: 8-byte initialization vector (first 8 bytes of encrypted TS packet)
   data: output buffer (bytes 8+ of TS packet, modified in place)
   len: number of bytes to decrypt (typically len-8)
   Exact port of dvbcsa_stream_xor from libdvbcsa.                       */
static void stream_xor(const u8 *cw, const u8 *iv, u8 *data, u32 len) {
    u64 A, B;
    u32 pqzyx = 0, cfed = 0;
    u32 i;

    /* Load A and B from nibble-swapped CW (little-endian 32-bit each) */
    A = (u64)cw[0] | ((u64)cw[1] << 8) | ((u64)cw[2] << 16) | ((u64)cw[3] << 24);
    B = (u64)cw[4] | ((u64)cw[5] << 8) | ((u64)cw[6] << 16) | ((u64)cw[7] << 24);

    /* 32 initialization rounds (8 IV bytes x 4 rounds each) */
    for (i = 0; i < 8; i++) {
        stream_init_round(iv[i],             &A, &B, &pqzyx, &cfed);
        stream_init_round(swap_nbl(iv[i]),   &A, &B, &pqzyx, &cfed);
        stream_init_round(iv[i],             &A, &B, &pqzyx, &cfed);
        stream_init_round(swap_nbl(iv[i]),   &A, &B, &pqzyx, &cfed);
    }

    /* Generate stream and XOR into data (4 rounds per output byte) */
    for (i = 0; i < len; i++) {
        stream_round(&A, &B, &pqzyx, &cfed);
        data[i] ^= stream_out[GETD(cfed) & 0xf] & 0xc0;

        stream_round(&A, &B, &pqzyx, &cfed);
        data[i] ^= stream_out[GETD(cfed) & 0xf] & 0x30;

        stream_round(&A, &B, &pqzyx, &cfed);
        data[i] ^= stream_out[GETD(cfed) & 0xf] & 0x0c;

        stream_round(&A, &B, &pqzyx, &cfed);
        data[i] ^= stream_out[GETD(cfed) & 0xf] & 0x03;
    }
}

/* ================================================================
   Block cipher - exact port from libdvbcsa/dvbcsa_block.c + dvbcsa_key.c
   ================================================================ */

/* Key permutation - exact from libdvbcsa/dvbcsa_key.c */
static u64 key_permute_block(u64 k) {
    u64 n = 0;
    n  = kperm[0][k & 0xff];  k >>= 8;
    n |= kperm[1][k & 0xff];  k >>= 8;
    n |= kperm[2][k & 0xff];  k >>= 8;
    n |= kperm[3][k & 0xff];  k >>= 8;
    n |= kperm[4][k & 0xff];  k >>= 8;
    n |= kperm[5][k & 0xff];  k >>= 8;
    n |= kperm[6][k & 0xff];  k >>= 8;
    n |= kperm[7][k & 0xff];
    return n;
}

/* Generate 56-byte key schedule from 8-byte CW.
   kk[56] = output expanded key.
   Exact port of dvbcsa_key_schedule_block from libdvbcsa.  */
static void key_schedule_block(const u8 *cw, u8 *kk) {
    u64 k[7];
    int i, j;

    /* k[6] = LE64(cw) */
    k[6] = (u64)cw[0]       | ((u64)cw[1] << 8)  | ((u64)cw[2] << 16) | ((u64)cw[3] << 24) |
           ((u64)cw[4] << 32) | ((u64)cw[5] << 40) | ((u64)cw[6] << 48) | ((u64)cw[7] << 56);

    for (i = 6; i > 0; i--)
        k[i - 1] = key_permute_block(k[i]);

    for (i = 0; i < 7; i++)
        for (j = 0; j < 8; j++)
            kk[i * 8 + j] = (u8)((k[i] >> (j * 8)) ^ i);
}

/* Block decrypt - 8 bytes in-place.
   Exact port of dvbcsa_block_decrypt from libdvbcsa. */
static void block_decrypt(const u8 *kk, const u8 *in, u8 *out) {
    u8 W[8];
    int i;

    for (i = 0; i < 8; i++) W[i] = in[i];

    for (i = 55; i >= 0; i--) {
        u8 S = block_sbox[kk[i] ^ W[6]];
        u8 L = W[7] ^ S;

        W[7] = W[6];
        W[6] = W[5] ^ block_perm[S];
        W[5] = W[4];
        W[4] = W[3] ^ L;
        W[3] = W[2] ^ L;
        W[2] = W[1] ^ L;
        W[1] = W[0];
        W[0] = L;
    }

    for (i = 0; i < 8; i++) out[i] = W[i];
}

/* ================================================================
   Full CSA decrypt for one 16-byte packet.
   cw[8]:   8-byte control word (private, not nibble-swapped)
   cws[8]:  nibble-swapped control word (for stream cipher)
   kk[56]:  expanded key schedule
   data[16]: TS packet data - decrypted in place.
   Exact port of dvbcsa_decrypt(len=16) from libdvbcsa.           */
static void csa_decrypt_packet(const u8 *cws, const u8 *kk,
                               u8 *data) {
    int i, j;

    /* Step 1: stream XOR on residual bytes (8..15) using IV = data[0..7] */
    stream_xor(cws, data, data + 8, 8);

    /* Step 2: block decrypt first 8 bytes */
    block_decrypt(kk, data, data);

    /* Step 3: chain — dvbcsa_xor_64(data[i-8], data[i]) does data[i-8] ^= data[i] */
    for (i = 8; i < 16; i += 8) {
        for (j = 0; j < 8; j++)
            data[i - 8 + j] ^= data[i + j];
        block_decrypt(kk, data + i, data + i);
    }
}

/* ================================================================
   Quick PES header check on first packet.
   Does stream_xor + block_decrypt + chain XOR on first 16 bytes.
   Returns true if final decrypted bytes 0..2 == 0x00 0x00 0x01.
   data is __global (from probedata buffer).                       */
static bool quick_check_pes(const u8 *cws, const u8 *kk,
                            __global const u8 *data) {
    u8 pkt[16];
    int i;
    for (i = 0; i < 16; i++) pkt[i] = data[i];

    /* Stream XOR on residual (bytes 8..15) using IV = pkt[0..7] */
    stream_xor(cws, pkt, pkt + 8, 8);

    /* Block decrypt first 8 bytes */
    block_decrypt(kk, pkt, pkt);

    /* Chain XOR: final[0..7] = BD[0..7] ^ S[8..15] */
    for (i = 0; i < 8; i++) pkt[i] ^= pkt[8 + i];

    return (pkt[0] == 0x00 && pkt[1] == 0x00 && pkt[2] == 0x01);
}

/* ================================================================
   Build control word from 32-bit outer key + 16-bit inner key.
   cw[8] = output 8-byte CW.
   cws[8] = output nibble-swapped CW.
   kernel_key32 = 32-bit outer key (bytes 0,1,2,4 packed).
   inner = 16-bit inner key (bytes 5,6 packed as [byte5 << 8 | byte6]).
   Byte 3 = checksum of bytes 0,1,2.
   Byte 7 = checksum of bytes 4,5,6.                                 */
static void build_cw(u32 kernel_key32, u16 inner, u8 *cw, u8 *cws) {
    int i;
    cw[0] = (u8)(kernel_key32 >> 24);
    cw[1] = (u8)(kernel_key32 >> 16);
    cw[2] = (u8)(kernel_key32 >> 8);
    cw[3] = cw[0] + cw[1] + cw[2];
    cw[4] = (u8)(kernel_key32);
    cw[5] = (u8)(inner >> 8);
    cw[6] = (u8)(inner);
    cw[7] = cw[4] + cw[5] + cw[6];

    /* Compute nibble-swapped CW for stream cipher */
    for (i = 0; i < 8; i++) {
        cws[i] = (u8)(((cw[i] & 0xf0) >> 4) | ((cw[i] & 0x0f) << 4));
    }
}

/* ================================================================
   Main brute-force kernel.
   Each work-item tests one outer key and iterates over the 16-bit
   inner key space.                                                 */

__kernel void aycwabtu_search(
    __global const u8  *probedata,   /* 3 x 16 bytes of encrypted TS      */
    __global volatile u32 *found,    /* output: [flag, cw_hi, cw_lo]       */
    u32 key_start,                   /* start of outer 32-bit key range    */
    u32 inner_start,                 /* start of inner key loop            */
    u32 inner_count)                 /* number of inner keys to test       */
{
    u32 gid = get_global_id(0);
    u32 outer_key = key_start + gid;

    /* Quick bounds check and early-exit check */
    if (found[0] != 0) return;

    /* Work buffers (private memory) */
    u8 cw[8], cws[8], kk[56];
    u8 pkt[16];
    u32 inner, inner_end;
    int i, j;

    /* Inner key loop — use u32 to avoid overflow at 65536 */
    inner_end = inner_start + inner_count;
    for (inner = inner_start;
         inner < inner_end;
         inner++) {

        build_cw(outer_key, (u16)inner, cw, cws);
        key_schedule_block(cw, kk);

        /* ---- Quick check on first packet: stream + block + chain XOR ---- */
        if (!quick_check_pes(cws, kk, probedata))
            continue;

        /* ---- Full verification on all 3 packets ---- */
        bool ok = true;
        for (i = 0; i < 3 && ok; i++) {
            for (j = 0; j < 16; j++)
                pkt[j] = probedata[i * 16 + j];
            csa_decrypt_packet(cws, kk, pkt);
            if (pkt[0] != 0x00 || pkt[1] != 0x00 || pkt[2] != 0x01)
                ok = false;
        }

        if (ok) {
            /* Key confirmed - atomically write to output */
            if (atomic_cmpxchg(&found[0], 0, 1) == 0) {
                found[1] = ((u32)cw[0] << 24) | ((u32)cw[1] << 16) |
                           ((u32)cw[2] <<  8) |  (u32)cw[3];
                found[2] = ((u32)cw[4] << 24) | ((u32)cw[5] << 16) |
                           ((u32)cw[6] <<  8) |  (u32)cw[7];
            }
            return;
        }
    }
}
